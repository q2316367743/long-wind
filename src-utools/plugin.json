{
  "$schema": "../node_modules/utools-api-types/resource/utools.schema.json",

  "name": "long-wind",
  "title": "长风寄锦",
  "description": "长风寄锦",
  "version": "2.0.1",

  "main": "dist/index.html",
  "preload": "preload.js",
  "logo": "public/logo.png",
  "platform": ["win32", "darwin", "linux"],
  "development": {
    "main": "http://localhost:5173/"
  },
  "pluginSetting": {
    "single": true,
    "height": 0
  },
  "features": [
    {
      "code": "launch",
      "explain": "长风寄锦",
      "icon": "public/logo.png",
      "platform": ["win32", "darwin", "linux"],
      "cmds": ["长风寄锦", "下载器"]
    },
    {
      "code": "link",
      "cmds": [
        {
          "type": "regex",
          "label": "下载链接",
          "match": "/^https?:\\/\\/\\S+$/i",
          "minLength": 1,
          "maxLength": 1000
        }
      ]
    }
  ]
}
